{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker",
        "exec",
        "-i",
        "-e",
        "CONTEXT7_API_KEY",
        "mcp_context7",
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "filesystem-personal": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker",
        "exec",
        "-i",
        "-e",
        "FILESYSTEM_PATH",
        "mcp_filesystem_personal",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Volumes/Data/my-labs"
      ],
      "env": {
        "FILESYSTEM_PATH": "${FILESYSTEM_PATH}"
      }
    },
    "github-personal": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker",
        "exec",
        "-i",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "mcp_github_personal",
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "jira": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker",
        "exec",
        "-i",
        "-e",
        "JIRA_HOST",
        "-e",
        "JIRA_EMAIL",
        "-e",
        "JIRA_API_TOKEN",
        "mcp_jira",
        "npx",
        "-y",
        "@tarasrushchak/jira-mcp-server"
      ],
      "env": {
        "JIRA_HOST": "${JIRA_HOST}",
        "JIRA_EMAIL": "${JIRA_EMAIL}",
        "JIRA_API_TOKEN": "${JIRA_API_TOKEN}"
      }
    },
    "slack": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker",
        "exec",
        "-i",
        "-e",
        "SLACK_BOT_TOKEN",
        "-e",
        "SLACK_TEAM_ID",
        "-e",
        "SLACK_CHANNEL_IDS",
        "mcp_slack",
        "sh",
        "/Users/abi/.mcp/servers/run-slack.sh"
      ],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "SLACK_TEAM_ID": "${SLACK_TEAM_ID}",
        "SLACK_CHANNEL_IDS": "${SLACK_CHANNEL_IDS}"
      }
    }
  }
}