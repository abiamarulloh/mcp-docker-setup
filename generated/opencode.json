{
  "mcp": {
    "context7": {
      "type": "local",
      "command": "docker exec -i mcp_context7 npx -y @upstash/context7-mcp"
    },
    "filesystem-personal": {
      "type": "local",
      "command": "docker exec -i mcp_filesystem_personal npx -y @modelcontextprotocol/server-filesystem /Volumes/Data/my-labs"
    },
    "github-personal": {
      "type": "local",
      "command": "docker exec -i mcp_github_personal npx -y @modelcontextprotocol/server-github",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_TOKEN}"
      }
    }
  }
}