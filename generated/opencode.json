{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker",
        "exec",
        "-i",
        "mcp_context7",
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "filesystem-personal": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker",
        "exec",
        "-i",
        "mcp_filesystem_personal",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/data"
      ]
    },
    "github-personal": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker",
        "exec",
        "-i",
        "mcp_github_personal",
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_TOKEN}"
      }
    }
  }
}